<div class="container mt-3">
  <div class="row justify-content-md-center mt-4">
    <div class="col-md-6 bg-light p-4">
      <h1>Add a new Flat</h1>
      <%= simple_form_for(@flat) do |f| %>
      <%= f.input :name, class: "form-control" %>
      <%= f.input :address, class: "form-control" %>
      <%= f.input :description, class: "form-control" %>
      <%= f.input :number_of_guests, class: "form-control" %>
      <%= f.input :price_per_night, class: "form-control" %>
      <%= f.submit class: "btn btn-outline-primary rounded" %>
      <% end %>
    </div>
  </div>
</div>
