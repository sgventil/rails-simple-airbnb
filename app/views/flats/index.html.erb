<div class="container mt-3">
  <div class="row">
    <div class="col-12 mb-3">
      <h1>All our Flats (<%= @flats.count %>)</h1>
    </div>
  </div>
  <div class="row row-cols-md-3">
    <% @flats.each do |flat|%>
      <div class="col mb-4">
        <div class="card h-100 bg-light">
          <div class="card-image-top">
          </div>
          <div class="card-body d-flex flex-column p-0">
            <div class="card-content px-3 pt-3 h-100">
              <h4 class="card-title"><%= flat.name%></h4>
              <p class="card-tex"><%= flat.address%></p>
            </div>
            <div class="d-flex align-items-center px-3">
              <i class="fa-solid fa-user-group me-1"></i>
              <span class="me-4"><%= flat.number_of_guests %></span>
              <i class="fa-solid fa-euro-sign me-1"></i>
              <span><%= flat.price_per_night %></span>
            </div>
            <div class="card-footer bg-white mt-auto">
              <%= link_to "More Info", flat_path(flat), style: "text-decoration: none;" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <div>
</div>
